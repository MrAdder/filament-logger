{
    "name": "mradder/filament-logger",
    "description": "Activity logger for filament",
    "keywords": [
        "Z3d0X",
        "laravel",
        "filament-logger",
        "mradder"
    ],
    "homepage": "https://github.com/mradder/filament-logger",
    "license": "MIT",
    "authors": [
        {
            "name": "Ziyaan Hassan",
            "email": "ziyaan2010@gmail.com",
            "role": "Developer"
        },
        {
            "name": "Daniel Green",
            "email": "dgreen03@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^3.0",
        "illuminate/contracts": "^11.0 | ^12.0",
        "spatie/laravel-activitylog": "^4.5",
        "spatie/laravel-package-tools": "^1.13.5"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "nunomaduro/collision": "^8.0 | ^9.0",
        "orchestra/testbench": "^9.0 | ^10.0",
        "pestphp/pest": "^3.7 | ^4.0",
        "pestphp/pest-plugin-laravel": "^3.1 | ^4.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5 | ^12.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "MrAdder\\FilamentLogger\\": "src",
            "MrAdder\\FilamentLogger\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MrAdder\\FilamentLogger\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MrAdder\\FilamentLogger\\FilamentLoggerServiceProvider"
            ],
            "aliases": {
                "FilamentLogger": "MrAdder\\FilamentLogger\\Facades\\FilamentLogger"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
